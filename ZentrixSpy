local function FormatTable(tbl, indent)
    indent = indent or 0
    local str = ""

    for k,v in pairs(tbl) do
        local spacing = string.rep("  ", indent)

        if typeof(v) == "table" then
            str = str..spacing..tostring(k)..": {\n"
            str = str..FormatTable(v, indent + 1)
            str = str..spacing.."}\n"
        else
            str = str..spacing..tostring(k)..": "..tostring(v).."\n"
        end
    end

    return str
end

local function FormatArgs(args)
    local str = ""

    for i,v in ipairs(args) do
        if typeof(v) == "table" then
            str = str..i..": {\n"..FormatTable(v,1).."}\n"
        else
            str = str..i..": "..tostring(v).."\n"
        end
    end

    return str
end

local function ValueToString(v)
    if typeof(v) == "table" then
        local s = "{"
        for _,val in pairs(v) do
            s = s..tostring(val)..", "
        end
        return s.."}"
    else
        return tostring(v)
    end
end

local function GenerateCode(remote, method, args)
    local str = remote:GetFullName()..":"..method.."("

    for i,v in ipairs(args) do
        str = str..ValueToString(v)
        if i < #args then str = str..", " end
    end

    return str..")"
end

