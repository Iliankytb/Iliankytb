local function GetKey(remote, method, args)
    if SmartFilterEnabled then
        return remote.Name 
    else
        return remote:GetFullName().."|"..method.."|"..#args
    end
end

local function AddLog(remote, method, args, direction)
    if Blacklist[remote.Name] then return end

    local key = GetKey(remote, method, args)

    if LogCache[key] then
        local cache = LogCache[key]
        cache.Count += 1
        cache.Log.Count = cache.Count
        cache.Button.Text = remote.Name.." x"..cache.Count
        return
    end

    local log = {
        Name = remote.Name,
        Type = remote.ClassName,
        Path = remote:GetFullName(),
        Direction = direction,
        Args = args,
        Method = method,
        Remote = remote,
        Count = 1
    }

    local Btn = CreateLog(log)

    LogCache[key] = {
        Count = 1,
        Button = Btn,
        Log = log
    }
end
local executor, version = identifyexecutor()
if executor ~= "Solara" and executor ~= "Xeno" then
local mt = getrawmetatable(game)
setreadonly(mt, false)
local old = mt.__namecall

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if typeof(self) == "Instance" then
        if method == "FireServer" then
            AddLog(self, method, args, "Client → Server")

        elseif method == "InvokeServer" then
            local result = old(self, ...)
            AddLog(self, method.." (Return: "..tostring(result)..")", args, "Client → Server")
            return result
        end
    end

    return old(self, ...)
end)
else
print("The Executor "..executor.." don't Support 'getrawmetatable' and 'Hooks' functions so remotes from client don't work!")
end
for _,v in ipairs(game:GetDescendants()) do
    if v:IsA("RemoteEvent") then
        v.OnClientEvent:Connect(function(...)
            AddLog(v, "OnClientEvent", {...}, "Server → Client")
        end)
    end
end

