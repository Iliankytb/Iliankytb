local dragging, dragStart, startPos
TopBar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = i.Position
        startPos = Main.Position
        i.Changed:Connect(function()
            if i.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if dragging then
        local delta = i.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local minimized = false
local originalSize = Main.Size

Minimize.MouseButton1Click:Connect(function()
    minimized = not minimized

    if minimized then
        Tween(Main, {Size = UDim2.new(Main.Size.X.Scale, Main.Size.X.Offset, 0, 40)})
        LogsFrame.Visible = false
        DetailsFrame.Visible = false
    else
        Tween(Main, {Size = originalSize})
        LogsFrame.Visible = true
        DetailsFrame.Visible = true
    end
end)

local function FormatArgs(args)
    local str = ""
    for i,v in ipairs(args) do
        str = str..i..": "..tostring(v).."\n"
    end
    return str
end

local function GenerateCode(remote, method, args)
    local str = remote:GetFullName()..":"..method.."("
    for i,v in ipairs(args) do
        str = str..tostring(v)
        if i < #args then str = str..", " end
    end
    return str..")"
end

local function CreateLog(log)
    local Btn = Instance.new("TextButton", LogsFrame)
    Btn.Size = UDim2.new(1,-5,0,isMobile and 40 or 60)
    Btn.Text = log.Name
    Btn.TextScaled = true
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.Font = Enum.Font.Gotham
    Btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Instance.new("UICorner", Btn)

    Btn.MouseEnter:Connect(function()
        Tween(Btn, {BackgroundColor3 = Themes[CurrentTheme].Accent})
    end)

    Btn.MouseLeave:Connect(function()
        Tween(Btn, {BackgroundColor3 = Color3.fromRGB(40,40,40)})
    end)

    Btn.MouseButton1Click:Connect(function()
        Tween(Btn, {Size = UDim2.new(1,-5,0,65)})
        InfoLabel.Text =
            "Name: "..log.Name..
            "\nType: "..log.Type..
            "\nDirection: "..log.Direction..
            "\n\nArgs:\n"..FormatArgs(log.Args)..
            "\nCode:\n"..GenerateCode(log.Remote, log.Method, log.Args)
    end)
end

local function AddLog(remote, method, args, direction)
    local log = {
        Name = remote.Name,
        Type = remote.ClassName,
        Direction = direction,
        Args = args,
        Method = method,
        Remote = remote
    }

    CreateLog(log)
end
local executor, version = identifyexecutor()
if executor ~= "Solara" and executor ~= "Xeno" then
local mt = getrawmetatable(game)
setreadonly(mt, false)
local old = mt.__namecall

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if typeof(self) == "Instance" then
        if method == "FireServer" then
            AddLog(self, method, args, "Client → Server")

        elseif method == "InvokeServer" then
            local result = old(self, ...)
            AddLog(self, method.." (Return: "..tostring(result)..")", args, "Client → Server")
            return result
        end
    end

    return old(self, ...)
end)
else
print("The Executor:  "..executor.." don't Support 'getrawmetatable' and 'Hooks' functions so its not working!")
end
for _,v in ipairs(game:GetDescendants()) do
    if v:IsA("RemoteEvent") then
        v.OnClientEvent:Connect(function(...)
            AddLog(v, "OnClientEvent", {...}, "Server → Client")
        end)
    end
end

