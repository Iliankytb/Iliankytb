local function FilterLogs(text)
    text = string.lower(text)

    for _,data in pairs(LogCache) do
        local log = data.Log
        local btn = data.Button

        if string.find(string.lower(log.Name), text) then
            btn.Visible = true
        else
            btn.Visible = false
        end
    end
end

