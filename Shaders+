local function GetOrCreate(ClassName)
    local Object = Lighting:FindFirstChild(ClassName)

    if not Object then
        Object = Instance.new(ClassName)
        Object.Parent = Lighting
    end

    return Object
end

local function ApplyShaders()

    if not SettingsShaders.Enabled then
        return
    end

    if SettingsShaders.Lighting.Enabled then

        for Property,Value in pairs(SettingsShaders.Lighting) do
            if Property ~= "Enabled" then
                Lighting[Property] = Value
            end
        end

    end
    
    if SettingsShaders.Atmosphere.Enabled then

        local Atmosphere = GetOrCreate("Atmosphere")

        for Property,Value in pairs(SettingsShaders.Atmosphere) do
            if Property ~= "Enabled" then
                Atmosphere[Property] = Value
            end
        end

    end

    if SettingsShaders.Bloom.Enabled then

        local Bloom = GetOrCreate("BloomEffect")

        for Property,Value in pairs(SettingsShaders.Bloom) do
            if Property ~= "Enabled" then
                Bloom[Property] = Value
            end
        end

    end

    if SettingsShaders.Blur.Enabled then

        local Blur = GetOrCreate("BlurEffect")

        for Property,Value in pairs(SettingsShaders.Blur) do
            if Property ~= "Enabled" then
                Blur[Property] = Value
            end
        end

    end

    if SettingsShaders.ColorCorrection.Enabled then

        local CC = GetOrCreate("ColorCorrectionEffect")

        for Property,Value in pairs(SettingsShaders.ColorCorrection) do
            if Property ~= "Enabled" then
                CC[Property] = Value
            end
        end

    end
    
    if SettingsShaders.DepthOfField.Enabled then

        local DOF = GetOrCreate("DepthOfFieldEffect")

        for Property,Value in pairs(SettingsShaders.DepthOfField) do
            if Property ~= "Enabled" then
                DOF[Property] = Value
            end
        end

    end

    if SettingsShaders.SunRays.Enabled then

        local Rays = GetOrCreate("SunRaysEffect")

        for Property,Value in pairs(SettingsShaders.SunRays) do
            if Property ~= "Enabled" then
                Rays[Property] = Value
            end
        end

    end

end

local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

local CachedParts = {}

for _, Object in ipairs(workspace:GetDescendants()) do
    if Object:IsA("BasePart") then
        table.insert(CachedParts, Object)
    end
end

local LastUpdate = 0

RunService.Heartbeat:Connect(function(DeltaTime)

ApplyShaders()

    LastUpdate += DeltaTime

    if LastUpdate >= SettingsShaders.Raytracing.UpdateRate then
        LastUpdate = 0

        if SettingsShaders.Raytracing.Enabled then

            local CameraPosition = Camera.CFrame.Position

            for _, Part in ipairs(CachedParts) do

                local Distance = (CameraPosition - Part.Position).Magnitude

                if Distance <= SettingsShaders.Raytracing.MaxDistance then

                    Part.Reflectance =
                        SettingsShaders.Raytracing.Reflectance

                else

                    Part.Reflectance = 0

                end

            end

        end

    end

end)
